# ============================================================
# Sensing MCP — Environment Variables
# Copy this file to .env and fill in values
# ============================================================

# ── Reasoning LLM provider (decision classifier Stage 2) ─────
# Default: anthropic (Haiku). Set to openai to classify decisions with OpenAI
# chat-completions instead — for setups that avoid Anthropic entirely.
# Reuses OPENAI_API_KEY below. Embeddings are chosen via EMBEDDING_PROVIDER.
# LLM_PROVIDER=openai
# OpenAI reasoning model (only when LLM_PROVIDER=openai; default gpt-4o).
# WARNING: gpt-4o-mini can hallucinate fields under the structured-output JSON
# prompt — prefer gpt-4o / gpt-4.1 for extraction fidelity.
# OPENAI_LLM_MODEL=gpt-4o

# ── Required ─────────────────────────────────────────────────

# Anthropic API key (for decision classifier — Haiku model)
# https://console.anthropic.com — key starts with sk-ant-api03-
# Required UNLESS LLM_PROVIDER=openai (then OPENAI_API_KEY covers it).
ANTHROPIC_API_KEY=

# ── Embeddings — choose ONE provider ─────────────────────────
# Set EMBEDDING_PROVIDER to: openai | voyage | cohere
# Then set the corresponding API key below.

EMBEDDING_PROVIDER=openai

# Option A: OpenAI (recommended — text-embedding-3-small)
# Cost: ~$0.00002 per 1000 tokens. Essentially free for this use case.
# Get key at: https://platform.openai.com/api-keys (sk-proj-… or sk-…)
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Option B: Voyage AI (fast + cheap alternative)
# Cost: ~$0.000025 per 1000 tokens.
# Get key at: https://www.voyageai.com
# VOYAGE_API_KEY=pa-...
# VOYAGE_EMBEDDING_MODEL=voyage-3-lite

# Option C: Cohere (good quality, similar cost)
# Cost: ~$0.0001 per 1000 tokens.
# Get key at: https://dashboard.cohere.com
# COHERE_API_KEY=...
# COHERE_EMBEDDING_MODEL=embed-english-v3.0

# ── Perception API ────────────────────────────────────────────
# Set after deploying Perception to Railway / Fly.io.
# Leave as default to test Sensing in isolation first.
PERCEPTION_API_URL=http://localhost:3001
PERCEPTION_API_KEY=

# ── Optional: classifier tuning ──────────────────────────────
# These are the designed starting values. Only change after
# instrumenting miss rates from real session data.

# Decision classifier
DECISION_CONFIDENCE_MIN=0.60    # below this = discard signal
DECISION_CONFIDENCE_HIGH=0.90   # above this = write immediately

# Topic shift classifier
TOPIC_SHIFT_THRESHOLD=0.35      # cosine distance to trigger shift
TOPIC_SHIFT_WINDOW_SIZE=3       # how many past messages to compare

# Contradiction detection
SIMILARITY_LINK_THRESHOLD=0.82  # above this = check for contradiction

# Buffer
BUFFER_MAX_SIZE=200             # max turns before dropping oldest
FLUSH_GRACE_WINDOW_MS=2000      # deprecated — end_session no longer waits; kept for compatibility
TOPIC_SHIFT_INLINE_TIMEOUT_MS=1500  # max ms to wait on embedding before record_turn returns

# Session registry mirror — active sessions are mirrored to this JSON file so
# a restarted MCP server (editor reconnect, crash, upgrade) resumes them
# transparently instead of erroring on sensing_record_turn.
# SENSING_SESSION_REGISTRY_PATH=~/.robrain/sensing-sessions.json
