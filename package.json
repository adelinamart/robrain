{
  "name": "robrain",
  "version": "0.1.9",
  "description": "Institutional memory for AI coding agents — capture decisions, rejected alternatives, and rationale across sessions",
  "private": true,
  "packageManager": "pnpm@10.33.3",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm -r --parallel dev",
    "typecheck": "pnpm -r typecheck",
    "docker:up": "docker compose -f docker/docker-compose.yml --env-file .env up -d",
    "docker:down": "docker compose -f docker/docker-compose.yml --env-file .env down"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.4.0"
  }
}
